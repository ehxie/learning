#!/bin/bash

sketchybar --remove '/.*/'

# ========================================================
# 核心栏设置
# margin 让 bar 窗口仅占按钮区域宽度，不拦截两侧点击
# 1512 宽屏幕: bar 窗口 312px 宽 (1512-1200)，居中
# 调整 margin 适配你的屏幕宽度和按钮数量
# ========================================================
sketchybar --bar height=36 \
                 color=0x00000000 \
                 border_width=0 \
                 padding_left=0 \
                 padding_right=0 \
                 margin=600 \
                 position=top \
                 y_offset=0 \
                 topmost=on

# 动画设置：开启平滑动画，并在隐藏时继续更新
sketchybar --default updates=on

# 全局默认样式
PLUGIN_DIR="$HOME/.config/sketchybar/plugins"
sketchybar --default background.corner_radius=6 \
                     background.height=24 \
                     icon.padding_left=8 \
                     icon.padding_right=8 \
                     label.padding_left=0 \
                     label.padding_right=0 \
                     padding_left=4 \
                     padding_right=4 \
                     icon.font="sketchybar-app-font:Regular:16.0" \
                     label.drawing=off

# ========================================================
# 桌面指示器 (Space Indicators) - 适配多显示器
# ========================================================
# 注册自定义事件，用于接收 yabai 的窗口变动信号
sketchybar --add event window_change

# 动态获取所有桌面及其对应的显示器，并创建对应的胶囊
yabai -m query --spaces | jq -r '.[] | "\(.index) \(.display)"' | while read -r sid did; do
  sketchybar --add space space.$sid e \
             --set space.$sid space=$sid \
                              display=$did \
                              icon="-" \
                              script="$PLUGIN_DIR/space.sh" \
             --subscribe space.$sid space_change \
                                    window_change \
                                    front_app_switched
done

sketchybar --update
